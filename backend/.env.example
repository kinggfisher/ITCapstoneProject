# Django basic
SECRET_KEY=your_secret_key_here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Local development 
# True = use SQLite (default for local dev)
# False = use PostgreSQL (e.g. Supabase)
USE_SQLITE=True

# PostgreSQL / Supabase (optional)
# Set USE_SQLITE=False to use this

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password_here

# PostgreSQL Configuration
# (Only used when USE_SQLITE=False)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=your_db_host_here   # e.g. db.xxxxx.supabase.co
DB_PORT=5432                # 5432 = direct / 6543 = pooler

# 5432 = direct connection
# 6543 = Supabase pooler
DB_PORT=5432

# Gmail SMTP credentials (used when EMAIL_PROVIDER=gmail)
EMAIL_HOST_USER=xxx@gmail.com
EMAIL_HOST_PASSWORD=


# Resend API (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
